# Environment variables for Shopify Truckload Splitter
# (Set these in Render → Environment, do NOT commit to GitHub)

# 🔑 Admin API access token from Shopify (replace with your real token)
SHOPIFY_ACCESS_TOKEN=your_admin_api_token_here

# 🛡️ Webhook secret from your Shopify app settings (replace with your real secret)
SHOPIFY_API_SECRET=your_app_secret_here

# 🏬 Your store domain (no https://, no trailing slash)
SHOP=houston-parts-portal.myshopify.com

# 📅 Shopify API version (must be a supported release, e.g. 2025-01 if available)
API_VERSION=2026-04

# ⚙️ PORT is provided automatically by Render, do not set manually
